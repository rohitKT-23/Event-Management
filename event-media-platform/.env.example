# ──────────────────────────────────────────────────────────────────
# Event & Media Management Platform — environment template
# Copy to `.env` (monorepo root) and fill in real values.
# Both apps/api and apps/web read from this single root file.
# ──────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=emp
LOG_LEVEL=info

# ── API server ────────────────────────────────────────────────────
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Local docker-compose maps Postgres to host port 5433 by default.
DATABASE_URL=postgresql://emp:emp_dev_password@localhost:5433/emp?schema=public
# Used by docker-compose to provision the postgres container
POSTGRES_USER=emp
POSTGRES_PASSWORD=emp_dev_password
POSTGRES_DB=emp
POSTGRES_PORT=5433

# ── Redis (cache + BullMQ queues) ─────────────────────────────────
REDIS_URL=redis://localhost:6380
REDIS_PORT=6380

# ── Auth / JWT ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_min_16_chars
JWT_REFRESH_SECRET=change_me_min_16_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
COOKIE_DOMAIN=localhost
# Set true in production (HTTPS)
COOKIE_SECURE=false

# ── Google OAuth (optional) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── AWS S3 + Rekognition ──────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_ORIGINAL=emp-media-original
S3_BUCKET_PROCESSED=emp-media-processed
S3_BUCKET_WATERMARKED=emp-watermarked
S3_BUCKET_AVATARS=emp-avatars
S3_BUCKET_SELFIES=emp-selfies
REKOGNITION_COLLECTION_ID=emp-faces
# Optional CloudFront CDN in front of S3
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_PATH=

# ── AI (OpenAI vision captions, optional) ─────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=EMP <onboarding@resend.dev>

# ── Virus scanning (optional ClamAV) ──────────────────────────────
VIRUS_SCAN_ENABLED=false
CLAMAV_HOST=
CLAMAV_PORT=3310

# ── Rate limiting / quotas ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
UPLOAD_DAILY_LIMIT_MB=500

# ── Frontend (Next.js — must be NEXT_PUBLIC_ to reach the browser) ─
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# Public CloudFront/CDN domain for displaying processed media
NEXT_PUBLIC_CDN_URL=
