# ──────────────────────────────────────────────────────────────────
# Event & Media Management Platform — Environment Configuration
# Copy to .env and fill in real values.
# ──────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=emp
LOG_LEVEL=info

# ── API server ────────────────────────────────────────────────────
API_PORT=4000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=emp
POSTGRES_PASSWORD=emp_dev_password
POSTGRES_DB=emp
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
DATABASE_URL=postgresql://emp:emp_dev_password@localhost:5433/emp?schema=public

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6380

# ── Auth / JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── MinIO (local S3) ──────────────────────────────────────────────
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003

# ── AWS ───────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_ORIGINAL=emp-media-original
S3_BUCKET_PROCESSED=emp-media-processed
S3_BUCKET_WATERMARKED=emp-watermarked
S3_BUCKET_AVATARS=emp-avatars
S3_BUCKET_SELFIES=emp-selfies
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_PATH=

# ── AI services ───────────────────────────────────────────────────
REKOGNITION_COLLECTION_ID=emp-faces
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Email (SendGrid/SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=
EMAIL_FROM=no-reply@emp.local

# ── Rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
UPLOAD_DAILY_LIMIT_MB=500

# ── Frontend (Next.js — must be prefixed NEXT_PUBLIC_) ────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=EMP
